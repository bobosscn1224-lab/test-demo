# DeepSeek API (Anthropic-compatible endpoint)
ANTHROPIC_API_KEY=sk-your-api-key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
CLAUDE_MODEL=deepseek-v4-pro
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# Embeddings — SiliconFlow API (OpenAI-compatible)
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# Voice
DEFAULT_VOICE_ID=zh-CN-YunxiNeural
WHISPER_MODEL_SIZE=small

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/digital_twin.db

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db

# Knowledge Base — local directories to watch and index
WATCH_DIRS=["D:/your/knowledge/dir"]

# Server
HOST=0.0.0.0
PORT=8001
CORS_ORIGINS=["http://localhost:5173"]

# Active persona (slug)
ACTIVE_PERSONA=default
