{
  "name": "weekly_report",
  "version": "1.0.0",
  "description": "根据周报模板智能生成周报：连接飞书获取本周消息和会议，分析工作内容，按模板格式自动填充",
  "triggers": ["写周报", "周报", "生成周报", "weekly report", "帮我写周报"],
  "keywords": ["周报", "weekly", "工作周报", "周工作总结"],
  "category": "productivity",
  "icon": "📊",
  "author": "数字分身",
  "created_at": "2026-05-19",
  "requires": {
    "python_packages": ["openpyxl", "httpx"],
    "services": ["feishu_mcp", "llm_service"],
    "directories": ["工作周报"]
  },
  "workflow": {
    "steps": [
      "1. 解析用户消息中的日期范围（支持\"本周\"、\"下周\"、\"X月X日到X月X日\"等格式）",
      "2. 查找工作周报目录下的最新Excel模板",
      "3. 分析模板结构（列名、合并单元格、示例数据）",
      "4. 收集上下文：用户画像、飞书消息/会议、近期对话",
      "5. 使用LLM生成符合模板格式的填充内容",
      "6. 填充Excel并保存到工作周报目录",
      "7. 返回下载链接和内容摘要"
    ]
  },
  "template_format": {
    "columns": ["A-日期(datetime,合并单元格)", "B-上午/下午", "C-时间范围", "D-本周计划", "E-本周总结"],
    "naming": "{year_short}年周工作总结和下周计划-ZB-{start_month}.{start_day}-{end_month}.{end_day}.xlsx"
  },
  "mcp_integration": {
    "server": "http://mcppage.ruijie.com.cn:9810/mcp",
    "tools_used": ["search_messages", "get_calendar_events"],
    "fallback": "飞书Open API (lark-oapi SDK)"
  }
}
